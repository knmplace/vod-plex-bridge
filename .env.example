# =============================================================================
# VOD Plex Bridge - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Dispatcharr Connection (REQUIRED) ---
# URL where your Dispatcharr instance is accessible from the bridge container.
# If the bridge runs on the same host as Dispatcharr, use http://localhost:<port>
# If Dispatcharr is behind a VPN container, use the VPN container's mapped port.
DISPATCHARR_URL=http://localhost:9191
# API key for authenticated Dispatcharr endpoints (IP display, etc.)
# Generate one in Dispatcharr: Settings → API Keys → Generate
DISPATCHARR_API_KEY=

# --- Plex (REQUIRED) ---
# Your Plex server URL and token. The bridge creates .strm files that point
# back to itself, so Plex must be able to reach the bridge at BRIDGE_HOST:BRIDGE_PORT.
PLEX_URL=http://your-plex-ip:32400
PLEX_TOKEN=your-plex-token
PLEX_LIBRARY_ID=7

# --- Bridge Network ---
# BRIDGE_HOST: The IP/hostname that Plex will use to reach this bridge.
# This should be the host machine's LAN IP, not 0.0.0.0 or 127.0.0.1.
BRIDGE_HOST=your-host-ip
BRIDGE_PORT=8585

# --- TMDB (Optional but recommended) ---
# Used to enrich movie metadata (genres, descriptions, posters, runtime).
# Get a free API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
TMDB_READ_TOKEN=

# --- Paths (used in docker-compose.example.yml) ---
# DATA_DIR: Host directory for the bridge database and mapping files.
# PLEX_VOD_DIR: Host directory where .strm/.nfo files are written.
#               Plex must be able to read this directory.
DATA_DIR=/opt/vod-plex-bridge/data
PLEX_VOD_DIR=/mnt/media/plex-vod
