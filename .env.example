# =============================================================================
# VOD Plex Bridge - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Dispatcharr Connection (REQUIRED) ---
# URL where your Dispatcharr instance is accessible from the bridge container.
# Use the LAN IP of the host running Dispatcharr + its port.
# If Dispatcharr is behind a VPN container (e.g., gluetun), use the port
# that is mapped through the VPN container to the host.
DISPATCHARR_URL=http://192.168.x.x:9191

# API key for Dispatcharr (optional — used for VPN IP display in header).
# Generate one in Dispatcharr: Settings → API Keys → Generate
DISPATCHARR_API_KEY=

# --- Plex (REQUIRED) ---
# Your Plex server URL and authentication token.
# The bridge generates .strm files containing URLs that point back to itself,
# so Plex must be able to reach the bridge at BRIDGE_HOST:BRIDGE_PORT.
# How to find your Plex token: https://support.plex.tv/articles/204059436/
PLEX_URL=http://192.168.x.x:32400
PLEX_TOKEN=your-plex-token
# Library section ID — find it in Plex URL: /library/sections/7 → ID is 7
PLEX_LIBRARY_ID=7

# --- Bridge Network (REQUIRED) ---
# BRIDGE_HOST must be the LAN IP of this machine (NOT 0.0.0.0 or 127.0.0.1).
# Plex uses this address to reach the bridge for streaming.
BRIDGE_HOST=192.168.x.x
BRIDGE_PORT=8585

# --- Timezone ---
# Container timezone. Affects log timestamps and scheduled task times.
# List of valid values: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# --- TMDB (Optional but recommended) ---
# Enriches movie metadata with genres, descriptions, posters, and runtime.
# Get a free API key at https://www.themoviedb.org/settings/api
# You need EITHER the API key OR the read access token (v4), not both.
TMDB_API_KEY=
TMDB_READ_TOKEN=

# --- Paths ---
# DATA_DIR: Where the bridge stores its database and mapping files.
# PLEX_VOD_DIR: Where .strm/.nfo/poster files are written.
#               BOTH the bridge container AND Plex must be able to access this path.
DATA_DIR=./data
PLEX_VOD_DIR=./plex-vod
