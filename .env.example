# =============================================================
# VOD Plex Bridge — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================

# --- Required: Dispatcharr Connection ---
DISPATCHARR_URL=http://your-dispatcharr-host:9191
DISPATCHARR_API_KEY=your-dispatcharr-api-key

# --- Required: Bridge Network ---
BRIDGE_HOST=your-bridge-host-ip
BRIDGE_PORT=8585

# --- Required: Plex Integration ---
PLEX_URL=http://your-plex-host:32400
PLEX_TOKEN=your-plex-token
PLEX_LIBRARY_ID=7

# --- Optional: TMDB Enrichment (genres, posters, language detection) ---
TMDB_API_KEY=
TMDB_READ_TOKEN=

# --- Docker Compose Volume Paths ---
DATA_DIR=/etc/docker/plexbridge/data
PLEX_VOD_DIR=/mnt/media50/plex-vod
